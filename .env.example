# Suno AI to Whisk Automation - Environment Configuration
# Copy this file to .env and fill in your actual values

# Whisk AI Configuration
WHISK_API_KEY=your_whisk_api_key_here
WHISK_BASE_URL=https://whisk.ai/api

# Processing Configuration
BATCH_SIZE=5
MAX_WORKERS=4
TIMEOUT=300

# Logging Configuration
LOG_LEVEL=INFO

# Suno Downloads Directory (Windows Path)
# Update this to your actual Suno downloads directory
SUNO_DOWNLOADS_DIR=C:\\Users\\abstt\\OneDrive\\Documentos\\SUNO\\Suno Downloads
